# 計測（WARP / Supabase）の接続枠。
# 制作マスター指示書 第6章：いまは様子見段階。デザイン完成を優先し、
# Pro判断後にこの値を設定し ENABLED=true にすると計測が有効化される。
#
# 有効化するまでは未設定でOK（trackEvent は no-op）。

# Supabase プロジェクトURL（本格運用時は東京リージョン）
NEXT_PUBLIC_SUPABASE_URL=

# anon キー（events への insert のみ許可されたキー）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "true" にしたときだけ計測を送信する
NEXT_PUBLIC_ANALYTICS_ENABLED=false
